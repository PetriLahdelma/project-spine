{
  "name": "project-spine",
  "version": "0.9.2-beta.0",
  "description": "Context compiler for software projects. Turns brief + repo + design inputs into a repo-native operating layer.",
  "type": "module",
  "bin": {
    "spine": "./dist/cli.js",
    "spine-mcp": "./dist/mcp/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "skills",
    "scripts/postinstall-hint.mjs",
    "README.md",
    "PRD.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "launch:assets": "node scripts/generate-launch-assets.mjs",
    "launch:check": "node scripts/check-launch-assets.mjs",
    "pack:check": "node scripts/check-public-package.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npm run pack:check",
    "postinstall": "node scripts/postinstall-hint.mjs"
  },
  "keywords": [
    "ai",
    "coding-agents",
    "agents.md",
    "claude",
    "copilot",
    "cursor",
    "context-engineering",
    "project-kickoff",
    "design-system",
    "cli"
  ],
  "author": "Petri Lahdelma",
  "license": "MIT",
  "homepage": "https://projectspine.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/PetriLahdelma/project-spine.git"
  },
  "bugs": {
    "url": "https://github.com/PetriLahdelma/project-spine/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.2.2",
    "diff": "^9.0.0",
    "fast-glob": "^3.3.2",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "execa": "^9.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  }
}
